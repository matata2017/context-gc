{
  "_comment": "Replace ABSOLUTE_PATH_TO/context-gc with the real install path, e.g. /home/you/.claude/skills/context-gc or D:/context-gc. Relative paths break because hooks run from the target project's cwd, not the skill dir.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python ABSOLUTE_PATH_TO/context-gc/scripts/context_gc_hook.py sweep-guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python ABSOLUTE_PATH_TO/context-gc/scripts/context_gc_hook.py dirty-card"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python ABSOLUTE_PATH_TO/context-gc/scripts/context_gc_hook.py stop-reminder"
          }
        ]
      }
    ]
  }
}
